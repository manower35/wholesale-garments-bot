# Telegram Bot Token (Get this from @BotFather on Telegram)
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Google Gemini API Key (Get this from Google AI Studio)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Database file path (sqlite)
DB_PATH=database.db

# One-time token to claim admin status. Send this token as a message to your bot to become the admin.
ADMIN_SETUP_TOKEN=admin12345
